// ============================================================
//  Garment Supply Platform — Prisma schema (India-ready)
//  Database: PostgreSQL
//
//  CONVENTIONS
//  - Money is ALWAYS integer paise (₹250.00 -> 25000). Never floats.
//  - GST-EXCLUSIVE pricing: pricePaise is the pre-tax price; tax is
//    computed from gstRatePercent at checkout. (B2B norm.)
//  - Tax split: same-state buyer -> CGST + SGST; other-state -> IGST.
//    The customer's state + your seller state decide which applies.
//  - Prices, HSN, GST rate, etc. are SNAPSHOTTED onto OrderItem at
//    checkout so historical orders never change when a product does.
//
//  ASSUMPTIONS (flip any of these, say the word):
//  - Schema is GST-capable now; invoice PDF generation is later.
//  - Flat price + optional quantity tiers (PriceTier).
//  - Razorpay + COD + Credit + Bank transfer, with amount-due tracking.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
//  Enums
// ------------------------------------------------------------

enum Role {
  ADMIN
  AGENT
}

// Approval state of a shop-owner account. New registrations start PENDING and
// must be approved by the serving store's agent before they can sign in.
enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
}

// CRM lead pipeline.
enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

// Where a lead came from: a manually-entered prospect or a shop sign-up.
enum LeadSource {
  MANUAL
  SIGNUP
}

// Logged interaction on a lead or customer.
enum ActivityType {
  NOTE
  CALL
  VISIT
  EMAIL
}

// Unit of measure — garment supplies sell in more than just "pieces".
enum ProductUnit {
  PIECE
  DOZEN
  PACK
  BOX
  SET
  KILOGRAM
  METER
}

enum OrderStatus {
  PENDING // created, not yet confirmed/paid
  CONFIRMED // payment received OR credit order accepted
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

// Whether the money for an order has come in (handles credit/partial).
enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY // UPI / cards / netbanking
  COD // cash on delivery
  CREDIT // pay-later terms
  BANK_TRANSFER // NEFT / IMPS / RTGS
}

enum PaymentStatus {
  CREATED // initiated, awaiting confirmation
  PAID // verified
  FAILED
  REFUNDED
}

// ------------------------------------------------------------
//  Identity
// ------------------------------------------------------------

// Internal team members (your staff). Distinct from Customer.
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String?
  password String // bcrypt hash
  role     Role    @default(AGENT)
  isActive Boolean @default(true)

  // Agents belong to exactly one store and only see that store's work.
  // Admins have no store (storeId = null) and see everything.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  assignedLeads      Lead[]     @relation("LeadAssignee")
  authoredActivities Activity[] @relation("ActivityAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

// Shop owners — your customers. Phone is the primary identity in India.
model Customer {
  id        String  @id @default(uuid())
  shopName  String
  ownerName String?
  // Store the 10-digit number; +91 country code handled in app/validation.
  phone     String  @unique
  email     String?
  password  String? // bcrypt hash; null when using OTP-only login
  gstin     String? // 15-char GSTIN; required only if they want GST invoices

  // Credit terms. creditApproved is granted by an admin; CREDIT checkout is
  // only allowed when approved AND the order fits the available limit.
  creditLimitPaise Int     @default(0)
  creditDays       Int     @default(0) // e.g. 15 / 30 day terms
  creditApproved   Boolean @default(false)
  isActive         Boolean @default(true)

  // Registration approval — a new shop is PENDING until the serving store's
  // agent approves it; only APPROVED shops can sign in.
  status          CustomerStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String? // staff (User) who approved/rejected
  rejectionReason String?

  // The store that serves this customer's city (assigned at registration,
  // reassignable by admin). Their catalog/pricing/fulfilment come from it.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses  Address[]
  cart       Cart?
  orders     Order[]
  lead       Lead?
  activities Activity[]

  @@index([phone])
  @@index([storeId])
}

// ------------------------------------------------------------
//  Stores (city-specific fulfilment + agent assignment)
// ------------------------------------------------------------

// A physical store that stocks & ships for a set of cities, staffed by its
// own agents. Holds its own GST origin state (single state for now; the
// per-store stateCode lets tax go multi-state later without a rewrite).
model Store {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique // short handle, e.g. "PUN", "MUM"
  phone       String?
  addressLine String?
  city        String // home city
  state       String // Indian state name
  stateCode   String // 2-digit GST state code (e.g. "27" = Maharashtra)
  pincode     String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceAreas ServiceArea[]
  agents       User[]
  customers    Customer[]
  inventory    StoreProduct[]
  orders       Order[]
  leads        Lead[]

  @@index([stateCode])
}

// Cities/areas a store serves. A city maps to exactly one store, so customer
// routing is a single lookup on the normalized city name.
model ServiceArea {
  id      String @id @default(uuid())
  city    String @unique // normalized (lower-cased, trimmed) city/area name
  label   String // display name as entered
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Indian address. state + pincode matter for tax and delivery.
model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label     String? // "Shop", "Warehouse"
  line1     String
  line2     String?
  city      String
  state     String // Indian state name (decides CGST/SGST vs IGST)
  stateCode String? // 2-digit GST state code (e.g. "27" = Maharashtra)
  pincode   String // 6-digit PIN
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

// ------------------------------------------------------------
//  Catalog
// ------------------------------------------------------------

// Self-referencing so categories can nest (e.g. Packaging > Boxes).
model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  description String?
  brand       String?
  // Free-form search tags (e.g. "festive", "cotton", "kids") for friendlier
  // search beyond the product name.
  tags        String[] @default([])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  unit           ProductUnit @default(PIECE)
  hsnCode        String? // HSN code for GST invoicing
  gstRatePercent Int         @default(0) // GST slab: 0 / 5 / 12 / 18 / 28

  mrpPaise Int? // printed MRP, for display/discount reference (catalog default)
  moqQty   Int  @default(1) // minimum order quantity

  imageUrl  String?
  isActive  Boolean  @default(true) // hide without deleting
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Price & stock are PER-STORE — see StoreProduct. Product is the shared
  // catalog definition (name, category, HSN, GST rate, MOQ, image).
  storeProducts StoreProduct[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([categoryId])
}

// Per-store stock + price for a shared catalog product. A product is only
// sellable in a store once a StoreProduct row exists for it.
model StoreProduct {
  id        String  @id @default(uuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  pricePaise Int // this store's base selling price, GST-EXCLUSIVE, in paise
  mrpPaise   Int? // optional per-store MRP override (else Product.mrpPaise)
  stockQty   Int     @default(0)
  isActive   Boolean @default(true) // store can delist without affecting others

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceTiers StorePriceTier[]

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([productId])
}

// Quantity-break wholesale pricing, per store. "Buy >= minQty -> pay pricePaise
// each." A store-product with no tiers simply uses StoreProduct.pricePaise.
model StorePriceTier {
  id             String       @id @default(uuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  minQty         Int // tier applies at this quantity and above
  pricePaise     Int // per-unit price at this tier, GST-exclusive

  @@unique([storeProductId, minQty])
  @@index([storeProductId])
}

// ------------------------------------------------------------
//  Cart  (one active cart per customer, lives server-side)
// ------------------------------------------------------------

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Price is NOT stored here — it's resolved (incl. tier) at checkout,
  // so the cart always reflects current pricing.
  @@unique([cartId, productId]) // one row per product per cart
  @@index([cartId])
}

// ------------------------------------------------------------
//  Orders & payments
// ------------------------------------------------------------

model Order {
  id          String      @id @default(uuid())
  // Human-readable, e.g. "ORD-2026-00042". Generated at creation.
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      OrderStatus @default(PENDING)

  // Fulfilling store (ships the order). Drives stock + GST origin state.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // ---- Shipping address SNAPSHOT (so later edits don't alter the order) ----
  shipName    String
  shipLine1   String
  shipLine2   String?
  shipCity    String
  shipState   String
  shipPincode String
  shipPhone   String

  // ---- GST snapshot ----
  gstinUsed       String? // customer's GSTIN at order time, if any
  placeOfSupply   String // buyer state used to decide CGST/SGST vs IGST
  sellerStateCode String? // fulfilling store's GST state code at order time

  // ---- Money (all integer paise) ----
  subtotalPaise Int // sum of line subtotals, pre-tax
  discountPaise Int @default(0)
  deliveryPaise Int @default(0)
  cgstPaise     Int @default(0)
  sgstPaise     Int @default(0)
  igstPaise     Int @default(0)
  totalPaise    Int // grand total payable

  // ---- Payment state ----
  paymentMethod   PaymentMethod
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  amountPaidPaise Int                @default(0)
  amountDuePaise  Int                @default(0) // for credit / partial
  dueDate         DateTime? // for CREDIT orders

  // ---- Invoice (filled when a GST invoice is issued) ----
  invoiceNumber String?   @unique
  invoiceDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payments Payment[] // multiple allowed (partial / credit settlements)

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // ---- Snapshots taken at checkout ----
  productName    String
  hsnCode        String?
  unit           ProductUnit
  quantity       Int
  unitPricePaise Int // resolved price (incl. tier) at order time, pre-tax
  gstRatePercent Int

  // ---- Computed line amounts (integer paise) ----
  lineSubtotalPaise Int // unitPricePaise * quantity
  cgstPaise         Int @default(0)
  sgstPaise         Int @default(0)
  igstPaise         Int @default(0)
  lineTotalPaise    Int // subtotal + taxes

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  amountPaise Int
  status      PaymentStatus @default(CREATED)

  // Razorpay references (verify signature server-side before marking PAID)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Bank-transfer / offline reference (UTR, txn id) + any details the customer
  // or staff attach. Used for BANK_TRANSFER and manual settlements.
  reference String?
  note      String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
}

// ------------------------------------------------------------
//  CRM — leads & activities
// ------------------------------------------------------------

// A sales lead: a manually-entered prospect OR a shop sign-up, worked through
// the pipeline by the serving store's agent.
model Lead {
  id             String     @id @default(uuid())
  shopName       String
  contactName    String?
  phone          String
  email          String?
  city           String?
  stage          LeadStage  @default(NEW)
  source         LeadSource @default(MANUAL)
  estValuePaise  Int        @default(0)
  nextFollowUpAt DateTime?
  lostReason     String?

  // Scoping + ownership
  storeId      String?
  store        Store?  @relation(fields: [storeId], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("LeadAssignee", fields: [assignedToId], references: [id])

  // Linked shop account (set for SIGNUP leads, or once a prospect converts).
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  activities Activity[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([storeId])
  @@index([stage])
  @@index([assignedToId])
}

// A logged interaction (note/call/visit/email) on a lead or a customer.
model Activity {
  id         String       @id @default(uuid())
  type       ActivityType @default(NOTE)
  body       String
  followUpAt DateTime?

  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("ActivityAuthor", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([customerId])
  @@index([createdById])
}
