// ============================================================
//  Garment Supply Platform — Prisma schema (India-ready)
//  Database: PostgreSQL
//
//  CONVENTIONS
//  - Money is ALWAYS integer paise (₹250.00 -> 25000). Never floats.
//  - GST-EXCLUSIVE pricing: pricePaise is the pre-tax price; tax is
//    computed from gstRatePercent at checkout. (B2B norm.)
//  - Tax split: same-state buyer -> CGST + SGST; other-state -> IGST.
//    The customer's state + your seller state decide which applies.
//  - Prices, HSN, GST rate, etc. are SNAPSHOTTED onto OrderItem at
//    checkout so historical orders never change when a product does.
//
//  ASSUMPTIONS (flip any of these, say the word):
//  - Schema is GST-capable now; invoice PDF generation is later.
//  - Flat price + optional quantity tiers (PriceTier).
//  - Razorpay + COD + Credit + Bank transfer, with amount-due tracking.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
//  Enums
// ------------------------------------------------------------

enum Role {
  ADMIN
  AGENT
}

// Approval state of a shop-owner account. New registrations start PENDING and
// must be approved by the serving store's agent before they can sign in.
enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
}

// CRM lead pipeline.
enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

// Where a lead came from: a manually-entered prospect or a shop sign-up.
enum LeadSource {
  MANUAL
  SIGNUP
}

// Logged interaction on a lead or customer.
enum ActivityType {
  NOTE
  CALL
  VISIT
  EMAIL
}

// Unit of measure — garment supplies sell in more than just "pieces".
enum ProductUnit {
  PIECE
  DOZEN
  PACK
  BOX
  SET
  KILOGRAM
  METER
}

enum OrderStatus {
  PENDING // created, not yet confirmed/paid
  CONFIRMED // payment received OR credit order accepted
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

// Whether the money for an order has come in (handles credit/partial).
enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY // UPI / cards / netbanking
  COD // cash on delivery
  CREDIT // pay-later terms
  BANK_TRANSFER // NEFT / IMPS / RTGS
}

enum PaymentStatus {
  CREATED // initiated, awaiting confirmation
  PAID // verified
  FAILED
  REFUNDED
}

// ------------------------------------------------------------
//  Identity
// ------------------------------------------------------------

// Internal team members (your staff). Distinct from Customer.
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String?
  password String // bcrypt hash
  role     Role    @default(AGENT)
  isActive Boolean @default(true)

  // Agents belong to exactly one store and only see that store's work.
  // Admins have no store (storeId = null) and see everything.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  assignedLeads      Lead[]          @relation("LeadAssignee")
  authoredActivities Activity[]      @relation("ActivityAuthor")
  stockMovements     StockMovement[]
  orderEvents        OrderEvent[]
  quotations         Quotation[]     @relation("QuotationAuthor")
  purchaseOrders     PurchaseOrder[] @relation("PurchaseOrderAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

// Shop owners — your customers. Phone is the primary identity in India.
model Customer {
  id        String  @id @default(uuid())
  shopName  String
  ownerName String?
  // Store the 10-digit number; +91 country code handled in app/validation.
  phone     String  @unique
  email     String?
  password  String? // bcrypt hash; null when using OTP-only login
  gstin     String? // 15-char GSTIN; required only if they want GST invoices

  // Credit terms. creditApproved is granted by an admin; CREDIT checkout is
  // only allowed when approved AND the order fits the available limit.
  creditLimitPaise Int     @default(0)
  creditDays       Int     @default(0) // e.g. 15 / 30 day terms
  creditApproved   Boolean @default(false)
  isActive         Boolean @default(true)

  // Registration approval — a new shop is PENDING until the serving store's
  // agent approves it; only APPROVED shops can sign in.
  status          CustomerStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String? // staff (User) who approved/rejected
  rejectionReason String?

  // The store that serves this customer's city (assigned at registration,
  // reassignable by admin). Their catalog/pricing/fulfilment come from it.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses         Address[]
  cart              Cart?
  orders            Order[]
  lead              Lead?
  activities        Activity[]
  wishlist          WishlistItem[]
  couponRedemptions CouponRedemption[]
  quotations        Quotation[]

  @@index([phone])
  @@index([storeId])
}

// ------------------------------------------------------------
//  Stores (city-specific fulfilment + agent assignment)
// ------------------------------------------------------------

// A physical store that stocks & ships for a set of cities, staffed by its
// own agents. Holds its own GST origin state (single state for now; the
// per-store stateCode lets tax go multi-state later without a rewrite).
model Store {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique // short handle, e.g. "PUN", "MUM"
  phone       String?
  addressLine String?
  city        String // home city
  state       String // Indian state name
  stateCode   String // 2-digit GST state code (e.g. "27" = Maharashtra)
  pincode     String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceAreas   ServiceArea[]
  agents         User[]
  customers      Customer[]
  inventory      StoreProduct[]
  variantStock   StoreVariant[]
  orders         Order[]
  leads          Lead[]
  stockMovements StockMovement[]
  coupons        Coupon[]
  quotations     Quotation[]
  purchaseOrders PurchaseOrder[]

  @@index([stateCode])
}

// Cities/areas a store serves. A city maps to exactly one store, so customer
// routing is a single lookup on the normalized city name.
model ServiceArea {
  id      String @id @default(uuid())
  city    String @unique // normalized (lower-cased, trimmed) city/area name
  label   String // display name as entered
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Indian address. state + pincode matter for tax and delivery.
model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label     String? // "Shop", "Warehouse"
  line1     String
  line2     String?
  city      String
  state     String // Indian state name (decides CGST/SGST vs IGST)
  stateCode String? // 2-digit GST state code (e.g. "27" = Maharashtra)
  pincode   String // 6-digit PIN
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

// ------------------------------------------------------------
//  Catalog
// ------------------------------------------------------------

// Self-referencing so categories can nest (e.g. Packaging > Boxes).
model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  description String?
  brand       String?
  // Free-form search tags (e.g. "festive", "cotton", "kids") for friendlier
  // search beyond the product name.
  tags        String[] @default([])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  unit           ProductUnit @default(PIECE)
  hsnCode        String? // HSN code for GST invoicing
  gstRatePercent Int         @default(0) // GST slab: 0 / 5 / 12 / 18 / 28

  mrpPaise Int? // printed MRP, for display/discount reference (catalog default)
  moqQty   Int  @default(1) // minimum order quantity

  imageUrl  String?
  isActive  Boolean  @default(true) // hide without deleting
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Price & stock are PER-STORE — see StoreProduct. Product is the shared
  // catalog definition (name, category, HSN, GST rate, MOQ, image).
  storeProducts      StoreProduct[]
  variants           ProductVariant[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  stockMovements     StockMovement[]
  wishlistItems      WishlistItem[]
  quotationItems     QuotationItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([categoryId])
}

// An orderable variation of a product (e.g. "Red / M"). Price & stock are
// PER-STORE (see StoreVariant); this row is the shared definition (label, SKU,
// attributes, image). A product with no variants is sold via StoreProduct.
model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String // display label, e.g. "Red / M"
  sku        String? @unique
  attributes Json? // optional breakdown, e.g. { "size": "M", "color": "Red" }
  mrpPaise   Int? // optional per-variant MRP (else the product's)
  imageUrl   String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeVariants      StoreVariant[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  stockMovements     StockMovement[]
  quotationItems     QuotationItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([productId])
}

// Per-store price + stock for a variant (mirrors StoreProduct, per variant).
model StoreVariant {
  id        String         @id @default(uuid())
  storeId   String
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  pricePaise Int
  mrpPaise   Int?
  stockQty   Int     @default(0)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, variantId])
  @@index([storeId])
  @@index([variantId])
}

// Per-store stock + price for a shared catalog product. A product is only
// sellable in a store once a StoreProduct row exists for it.
model StoreProduct {
  id        String  @id @default(uuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  pricePaise Int // this store's base selling price, GST-EXCLUSIVE, in paise
  mrpPaise   Int? // optional per-store MRP override (else Product.mrpPaise)
  stockQty   Int     @default(0)
  isActive   Boolean @default(true) // store can delist without affecting others

  // Reordering: alert when stockQty <= reorderLevel (0 = no alert); reorderQty
  // is the suggested quantity to put on a purchase order.
  reorderLevel Int @default(0)
  reorderQty   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceTiers StorePriceTier[]

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([productId])
}

// Quantity-break wholesale pricing, per store. "Buy >= minQty -> pay pricePaise
// each." A store-product with no tiers simply uses StoreProduct.pricePaise.
model StorePriceTier {
  id             String       @id @default(uuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  minQty         Int // tier applies at this quantity and above
  pricePaise     Int // per-unit price at this tier, GST-exclusive

  @@unique([storeProductId, minQty])
  @@index([storeProductId])
}

// ------------------------------------------------------------
//  Cart  (one active cart per customer, lives server-side)
// ------------------------------------------------------------

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  // The chosen variant, when the product has variants (null = base product).
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Price is NOT stored here — it's resolved (incl. tier) at checkout,
  // so the cart always reflects current pricing. One line per (product,
  // variant) is enforced in the service (nullable variantId rules out a DB
  // unique that dedupes base-product lines reliably).
  @@index([cartId])
  @@index([cartId, productId])
}

// ------------------------------------------------------------
//  Orders & payments
// ------------------------------------------------------------

model Order {
  id          String      @id @default(uuid())
  // Human-readable, e.g. "ORD-2026-00042". Generated at creation.
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      OrderStatus @default(PENDING)

  // Fulfilling store (ships the order). Drives stock + GST origin state.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // ---- Shipping address SNAPSHOT (so later edits don't alter the order) ----
  shipName    String
  shipLine1   String
  shipLine2   String?
  shipCity    String
  shipState   String
  shipPincode String
  shipPhone   String

  // ---- GST snapshot ----
  gstinUsed       String? // customer's GSTIN at order time, if any
  placeOfSupply   String // buyer state used to decide CGST/SGST vs IGST
  sellerStateCode String? // fulfilling store's GST state code at order time

  // ---- Money (all integer paise) ----
  subtotalPaise Int // sum of line subtotals, pre-tax
  discountPaise Int     @default(0) // coupon discount (post-tax rebate)
  couponCode    String? // code applied at checkout, if any
  deliveryPaise Int     @default(0)
  cgstPaise     Int     @default(0)
  sgstPaise     Int     @default(0)
  igstPaise     Int     @default(0)
  totalPaise    Int // grand total payable

  // ---- Payment state ----
  paymentMethod   PaymentMethod
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  amountPaidPaise Int                @default(0)
  amountDuePaise  Int                @default(0) // for credit / partial
  dueDate         DateTime? // for CREDIT orders

  // ---- Invoice (filled when a GST invoice is issued) ----
  invoiceNumber String?   @unique
  invoiceDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items            OrderItem[]
  payments         Payment[] // multiple allowed (partial / credit settlements)
  events           OrderEvent[] // status-change history (placed/confirmed/shipped…)
  stockMovements   StockMovement[]
  couponRedemption CouponRedemption?

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  // The ordered variant, if any (null = base product).
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  // ---- Snapshots taken at checkout ----
  productName    String
  variantName    String? // variant label snapshot, e.g. "Red / M"
  hsnCode        String?
  unit           ProductUnit
  quantity       Int
  unitPricePaise Int // resolved price (incl. tier) at order time, pre-tax
  gstRatePercent Int

  // ---- Computed line amounts (integer paise) ----
  lineSubtotalPaise Int // unitPricePaise * quantity
  cgstPaise         Int @default(0)
  sgstPaise         Int @default(0)
  igstPaise         Int @default(0)
  lineTotalPaise    Int // subtotal + taxes

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  amountPaise Int
  status      PaymentStatus @default(CREATED)

  // Razorpay references (verify signature server-side before marking PAID)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Bank-transfer / offline reference (UTR, txn id) + any details the customer
  // or staff attach. Used for BANK_TRANSFER and manual settlements.
  reference String?
  note      String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
}

// ------------------------------------------------------------
//  CRM — leads & activities
// ------------------------------------------------------------

// A sales lead: a manually-entered prospect OR a shop sign-up, worked through
// the pipeline by the serving store's agent.
model Lead {
  id             String     @id @default(uuid())
  shopName       String
  contactName    String?
  phone          String
  email          String?
  city           String?
  stage          LeadStage  @default(NEW)
  source         LeadSource @default(MANUAL)
  estValuePaise  Int        @default(0)
  nextFollowUpAt DateTime?
  lostReason     String?

  // Scoping + ownership
  storeId      String?
  store        Store?  @relation(fields: [storeId], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("LeadAssignee", fields: [assignedToId], references: [id])

  // Linked shop account (set for SIGNUP leads, or once a prospect converts).
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  activities Activity[]
  quotations Quotation[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([storeId])
  @@index([stage])
  @@index([assignedToId])
}

// A logged interaction (note/call/visit/email) on a lead or a customer.
model Activity {
  id         String       @id @default(uuid())
  type       ActivityType @default(NOTE)
  body       String
  followUpAt DateTime?

  // GPS check-in for field visits (captured from the agent's device on a VISIT).
  latitude  Float?
  longitude Float?

  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("ActivityAuthor", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([customerId])
  @@index([createdById])
}

// ------------------------------------------------------------
//  Inventory ledger & order events (audit / traceability)
// ------------------------------------------------------------

enum StockMovementType {
  SALE // consumed by an order
  RESTOCK // stock added
  ADJUSTMENT // manual correction / CSV import
  RELEASE // returned to stock (cancellation / return)
}

// Append-only ledger of every per-store stock change — who/when/why, so stock
// is fully traceable rather than a single mutable number.
model StockMovement {
  id              String            @id @default(uuid())
  storeId         String
  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId       String
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  // The variant whose stock moved, when applicable.
  variantId       String?
  variant         ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  deltaQty        Int // signed: negative = consumed, positive = added
  type            StockMovementType
  reason          String?
  orderId         String?
  order           Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // The purchase order that added this stock, when it came from a PO receipt.
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  userId          String? // staff who triggered it, if any
  user            User?             @relation(fields: [userId], references: [id])
  createdAt       DateTime          @default(now())

  @@index([storeId, productId])
  @@index([orderId])
  @@index([purchaseOrderId])
}

// Status-change history for an order (placed, confirmed, packed, shipped,
// delivered…) — gives each event a timestamp and the staff member responsible.
model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())

  @@index([orderId])
}

// Centralised audit trail of important actions (who did what, to what, when).
// Decoupled from other tables (loose actorId/entityId) so it can log anything,
// including SYSTEM actions, without cascade concerns.
model AuditLog {
  id        String   @id @default(uuid())
  actorType String // STAFF | CUSTOMER | SYSTEM
  actorId   String?
  action    String // e.g. customer.approve, order.status, product.delete
  entity    String // Customer | Order | Product | Category | Store | Payment
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ------------------------------------------------------------
//  Wishlist  (a shop owner's saved products)
// ------------------------------------------------------------

// One row per (customer, product) the shop has saved for later. The unique
// constraint makes "is this wishlisted?" and toggling idempotent.
model WishlistItem {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
}

// ------------------------------------------------------------
//  Coupons & discounts
// ------------------------------------------------------------

enum CouponType {
  PERCENT // value = whole percent off the order subtotal (e.g. 10 = 10%)
  FIXED // value = flat paise off
}

// A promotional discount code. Applied post-tax to the order total (a rebate
// on the payable amount), so per-line GST is unaffected.
model Coupon {
  id          String     @id @default(uuid())
  code        String     @unique // stored upper-cased
  description String?
  type        CouponType
  value       Int // PERCENT: whole percent; FIXED: paise

  minOrderPaise    Int  @default(0) // minimum subtotal to qualify
  maxDiscountPaise Int? // cap for PERCENT coupons
  usageLimit       Int? // total redemptions allowed across all customers
  perCustomerLimit Int? // redemptions allowed per customer
  usedCount        Int  @default(0)

  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean   @default(true)

  // Optional restriction to a single store's customers.
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

// One row per successful application of a coupon to an order (drives usage
// limits and gives an audit trail of who redeemed what).
model CouponRedemption {
  id            String   @id @default(uuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discountPaise Int
  createdAt     DateTime @default(now())

  @@index([couponId])
  @@index([customerId])
}

// ------------------------------------------------------------
//  Purchasing (replenishment — closes the loop on the stock ledger)
// ------------------------------------------------------------

enum PurchaseOrderStatus {
  DRAFT // being built, editable
  ORDERED // placed with the supplier, awaiting goods
  PARTIAL // some lines received
  RECEIVED // fully received into stock
  CANCELLED
}

// A vendor that replenishes store stock.
model Supplier {
  id          String  @id @default(uuid())
  name        String
  phone       String?
  email       String?
  gstin       String?
  addressLine String?
  isActive    Boolean @default(true)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]

  @@index([name])
}

// A replenishment order to a supplier for a store. Receiving its lines adds
// stock and writes RESTOCK rows to the per-store ledger (with a back-link),
// so every unit that enters a store is traceable to a PO.
model PurchaseOrder {
  id       String              @id @default(uuid())
  poNumber String              @unique // e.g. "PO-2026-00012"
  status   PurchaseOrderStatus @default(DRAFT)

  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  createdById String?
  createdBy   User?   @relation("PurchaseOrderAuthor", fields: [createdById], references: [id])

  notes          String?
  expectedAt     DateTime? // expected delivery date
  totalCostPaise Int       @default(0)
  receivedAt     DateTime? // when fully received

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName   String
  variantName   String?
  orderedQty    Int
  receivedQty   Int     @default(0) // running total received across deliveries
  unitCostPaise Int // buy price per unit (GST handling is out of scope here)
  lineCostPaise Int

  @@index([purchaseOrderId])
  @@index([productId])
}

// ------------------------------------------------------------
//  Quotations (sales proposals — negotiable prices, convert to order)
// ------------------------------------------------------------

enum QuotationStatus {
  DRAFT // being built, editable
  SENT // shared with the shop
  ACCEPTED // shop agreed
  DECLINED // shop passed
  EXPIRED // past validUntil
  CONVERTED // turned into an order
}

// A priced proposal for a shop (an existing customer or a prospect lead). Lines
// snapshot a possibly-negotiated unit price; converting one creates a real order
// honouring those prices (tax is recomputed against the delivery address).
model Quotation {
  id          String          @id @default(uuid())
  quoteNumber String          @unique // e.g. "QUO-2026-00007"
  status      QuotationStatus @default(DRAFT)
  title       String?
  notes       String? // terms / cover note shown on the quote
  validUntil  DateTime?

  // Recipient: an onboarded customer and/or a pipeline lead (at least one).
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id])

  // Serving store (drives prices) + author.
  storeId     String?
  store       Store?  @relation(fields: [storeId], references: [id])
  createdById String?
  createdBy   User?   @relation("QuotationAuthor", fields: [createdById], references: [id])

  // GST context snapshot used for the indicative tax on the quote.
  placeOfSupply   String?
  sellerStateCode String?

  // Money (integer paise).
  subtotalPaise Int @default(0)
  cgstPaise     Int @default(0)
  sgstPaise     Int @default(0)
  igstPaise     Int @default(0)
  discountPaise Int @default(0) // negotiated lump-sum off the total
  totalPaise    Int @default(0)

  // Set once converted (loose link — kept simple, no Order back-relation).
  orderId     String? @unique
  orderNumber String?

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     QuotationItem[]

  @@index([customerId])
  @@index([leadId])
  @@index([storeId])
  @@index([status])
}

model QuotationItem {
  id          String          @id @default(uuid())
  quotationId String
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  // Snapshots (the proposed price may differ from the live store price).
  productName    String
  variantName    String?
  hsnCode        String?
  unit           ProductUnit
  quantity       Int
  unitPricePaise Int // proposed (possibly negotiated) unit price, pre-tax
  gstRatePercent Int

  lineSubtotalPaise Int
  cgstPaise         Int @default(0)
  sgstPaise         Int @default(0)
  igstPaise         Int @default(0)
  lineTotalPaise    Int

  @@index([quotationId])
  @@index([productId])
}
