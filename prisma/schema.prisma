// ============================================================
//  Garment Supply Platform — Prisma schema (India-ready)
//  Database: PostgreSQL
//
//  CONVENTIONS
//  - Money is ALWAYS integer paise (₹250.00 -> 25000). Never floats.
//  - GST-EXCLUSIVE pricing: pricePaise is the pre-tax price; tax is
//    computed from gstRatePercent at checkout. (B2B norm.)
//  - Tax split: same-state buyer -> CGST + SGST; other-state -> IGST.
//    The customer's state + your seller state decide which applies.
//  - Prices, HSN, GST rate, etc. are SNAPSHOTTED onto OrderItem at
//    checkout so historical orders never change when a product does.
//
//  ASSUMPTIONS (flip any of these, say the word):
//  - Schema is GST-capable now; invoice PDF generation is later.
//  - Flat price + optional quantity tiers (PriceTier).
//  - Razorpay + COD + Credit + Bank transfer, with amount-due tracking.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
//  Enums
// ------------------------------------------------------------

enum Role {
  ADMIN
  AGENT
}

// Unit of measure — garment supplies sell in more than just "pieces".
enum ProductUnit {
  PIECE
  DOZEN
  PACK
  BOX
  SET
  KILOGRAM
  METER
}

enum OrderStatus {
  PENDING // created, not yet confirmed/paid
  CONFIRMED // payment received OR credit order accepted
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

// Whether the money for an order has come in (handles credit/partial).
enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY // UPI / cards / netbanking
  COD // cash on delivery
  CREDIT // pay-later terms
  BANK_TRANSFER // NEFT / IMPS / RTGS
}

enum PaymentStatus {
  CREATED // initiated, awaiting confirmation
  PAID // verified
  FAILED
  REFUNDED
}

// ------------------------------------------------------------
//  Identity
// ------------------------------------------------------------

// Internal team members (your staff). Distinct from Customer.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String // bcrypt hash
  role      Role     @default(AGENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shop owners — your customers. Phone is the primary identity in India.
model Customer {
  id        String   @id @default(uuid())
  shopName  String
  ownerName String?
  // Store the 10-digit number; +91 country code handled in app/validation.
  phone     String   @unique
  email     String?
  password  String? // bcrypt hash; null when using OTP-only login
  gstin     String? // 15-char GSTIN; required only if they want GST invoices

  // Credit terms (used only when an order is placed on CREDIT)
  creditLimitPaise Int     @default(0)
  creditDays       Int     @default(0) // e.g. 15 / 30 day terms
  isActive         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  cart      Cart?
  orders    Order[]

  @@index([phone])
}

// Indian address. state + pincode matter for tax and delivery.
model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label     String? // "Shop", "Warehouse"
  line1     String
  line2     String?
  city      String
  state     String // Indian state name (decides CGST/SGST vs IGST)
  stateCode String? // 2-digit GST state code (e.g. "27" = Maharashtra)
  pincode   String // 6-digit PIN
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

// ------------------------------------------------------------
//  Catalog
// ------------------------------------------------------------

// Self-referencing so categories can nest (e.g. Packaging > Boxes).
model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  name        String
  slug        String?     @unique
  description String?
  brand       String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])

  unit           ProductUnit @default(PIECE)
  hsnCode        String? // HSN code for GST invoicing
  gstRatePercent Int         @default(0) // GST slab: 0 / 5 / 12 / 18 / 28

  mrpPaise   Int? // printed MRP, for display/discount reference
  pricePaise Int // your base selling price, GST-EXCLUSIVE, in paise
  moqQty     Int  @default(1) // minimum order quantity
  stockQty   Int  @default(0)

  imageUrl  String?
  isActive  Boolean  @default(true) // hide without deleting
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceTiers PriceTier[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
}

// Quantity-break wholesale pricing. "Buy >= minQty -> pay pricePaise each."
// A product with no tiers simply uses Product.pricePaise.
model PriceTier {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQty     Int // tier applies at this quantity and above
  pricePaise Int // per-unit price at this tier, GST-exclusive

  @@unique([productId, minQty])
  @@index([productId])
}

// ------------------------------------------------------------
//  Cart  (one active cart per customer, lives server-side)
// ------------------------------------------------------------

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Price is NOT stored here — it's resolved (incl. tier) at checkout,
  // so the cart always reflects current pricing.
  @@unique([cartId, productId]) // one row per product per cart
  @@index([cartId])
}

// ------------------------------------------------------------
//  Orders & payments
// ------------------------------------------------------------

model Order {
  id          String      @id @default(uuid())
  // Human-readable, e.g. "ORD-2026-00042". Generated at creation.
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      OrderStatus @default(PENDING)

  // ---- Shipping address SNAPSHOT (so later edits don't alter the order) ----
  shipName    String
  shipLine1   String
  shipLine2   String?
  shipCity    String
  shipState   String
  shipPincode String
  shipPhone   String

  // ---- GST snapshot ----
  gstinUsed     String? // customer's GSTIN at order time, if any
  placeOfSupply String // state used to decide CGST/SGST vs IGST

  // ---- Money (all integer paise) ----
  subtotalPaise Int // sum of line subtotals, pre-tax
  discountPaise Int @default(0)
  deliveryPaise Int @default(0)
  cgstPaise     Int @default(0)
  sgstPaise     Int @default(0)
  igstPaise     Int @default(0)
  totalPaise    Int // grand total payable

  // ---- Payment state ----
  paymentMethod   PaymentMethod
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  amountPaidPaise Int                @default(0)
  amountDuePaise  Int                @default(0) // for credit / partial
  dueDate         DateTime? // for CREDIT orders

  // ---- Invoice (filled when a GST invoice is issued) ----
  invoiceNumber String?   @unique
  invoiceDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payments Payment[] // multiple allowed (partial / credit settlements)

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // ---- Snapshots taken at checkout ----
  productName    String
  hsnCode        String?
  unit           ProductUnit
  quantity       Int
  unitPricePaise Int // resolved price (incl. tier) at order time, pre-tax
  gstRatePercent Int

  // ---- Computed line amounts (integer paise) ----
  lineSubtotalPaise Int // unitPricePaise * quantity
  cgstPaise         Int @default(0)
  sgstPaise         Int @default(0)
  igstPaise         Int @default(0)
  lineTotalPaise    Int // subtotal + taxes

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  amountPaise Int
  status      PaymentStatus @default(CREATED)

  // Razorpay references (verify signature server-side before marking PAID)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
}
