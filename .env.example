# ----------------------------------------------------------------------------
# NH Styx Backend — Environment Variables
# Copy this file to `.env` and fill in the values.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# CORS — comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://nhstyx:nhstyx@localhost:5432/nhstyx?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-in-production
JWT_REFRESH_SECRET=change-me-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GST — your seller state (decides CGST+SGST vs IGST). 2-digit GST state code.
SELLER_STATE_CODE=27
SELLER_STATE_NAME=Maharashtra

# Delivery fee charged at checkout, in integer paise (0 = free)
DELIVERY_FEE_PAISE=0

# Razorpay (required only when customers choose the RAZORPAY payment method)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Anthropic — powers AI product search. If unset, search falls back to keywords.
ANTHROPIC_API_KEY=
AI_SEARCH_MODEL=claude-opus-4-8

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
